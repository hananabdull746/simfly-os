# ============================================
# SimFly OS v5.1 - Environment Variables
# ============================================

# WhatsApp Admin Number (with country code, no +)
# Example: 923001234567
ADMIN_NUMBER=923001234567

# Groq AI API Key (get from https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# ============================================
# FIREBASE SETUP (Real Database)
# ============================================
#
# Step 1: Go to Firebase Console → Project Settings → Service Accounts
# Step 2: Click "Generate new private key"
# Step 3: Download JSON file
# Step 4: Convert to base64 and paste here
#
# FIREBASE_SERVICE_ACCOUNT=eyJ0eXBl... (base64 string)

FIREBASE_SERVICE_ACCOUNT=your_base64_encoded_service_account_here

# ============================================
# Railway/Render Config
# ============================================
PORT=3000
NODE_ENV=production
