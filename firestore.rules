rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /conversations/{chatId} {
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
    match /stats/{statId} {
      allow read, write: if true;
    }
    match /orders/{orderId} {
      allow read, write: if true;
    }
  }
}
